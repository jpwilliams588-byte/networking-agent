# Copy this file to ".env" and paste in your two API keys.
# Do NOT share the .env file or commit it anywhere — it holds your secrets.

# Tavily web-search key — get one free at https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude (Anthropic) key — create one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Turso cloud database (so data survives server resets on the web).
# Leave BOTH blank to just use the local file. Get them free at https://turso.tech:
# create a database, copy its URL, then create a database token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
